#include<iostream>
using namespace std;

int main() {

int n;
string represent[10] = {
    "Greater than 9",
    "one", "two", "three", "four",
    "five", "six", "seven", "eight", "nine"
};

cin >> n;

if (n >= 1 && n <= 9) {
    cout << represent[n];
} 
else {
    cout << "Greater than 9";
}

return 0;
}
